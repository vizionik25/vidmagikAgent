# =============================================================================
# LLM Configuration for AI Shorts Creator
# =============================================================================
# Copy this file to .env and fill in your values.
# Docker Compose automatically reads .env files.

# Option 1: LM Studio (local LLM)
# Per https://docs.litellm.ai/docs/providers/lm_studio
LM_STUDIO_API_BASE=http://localhost:1234/v1
LLM_MODEL=ibm/granite-4-h-tiny
# LM_STUDIO_API_KEY=              # optional, default is empty

# Option 2: Cloud provider (just set the API key, model auto-detected)
# GEMINI_API_KEY=your-gemini-key
# OPENAI_API_KEY=sk-your-openai-key
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
